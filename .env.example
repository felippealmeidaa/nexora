APP_NAME=NEXORA API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false

# Para usar SQLite local: sqlite:///./academico.db
# Para usar SQLite na Oracle: sqlite:////srv/nexora/storage/academico.db
# Para usar PostgreSQL local: postgresql://username:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./academico.db
AUTO_CREATE_SCHEMA=false

# Em desenvolvimento local, se deixar vazio o sistema cria valores persistidos em .nexora-runtime/.
# Em producao, configure os dois explicitamente no ambiente.
SECRET_KEY=troque-por-um-segredo-forte-com-no-minimo-32-caracteres
LYCEUM_CREDENTIALS_KEY=defina-uma-chave-separada-para-criptografia-das-credenciais-lyceum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_COOKIE_NAME=nexora_access
REFRESH_COOKIE_NAME=nexora_refresh
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
MAX_ACTIVE_SESSIONS_PER_USER=5

# Em producao com Cloudflare Pages, use o dominio final do frontend.
# Exemplo: https://nexora.pages.dev,https://app.seudominio.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

MAX_UPLOAD_BYTES=8388608
MAX_HISTORICAL_RECORDS_PER_FILE=5000
ENABLE_GEMINI_UPLOAD_FALLBACK=true

ALLOW_LYCEUM_CPF_PASSWORD_FALLBACK=false

# Manter false fora de ambientes controlados.
ENABLE_DEMO_BOOTSTRAP=false
SEED_EMPTY_DATABASE=false
CREATE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@nexora.local
DEFAULT_ADMIN_PASSWORD=
ENABLE_STARTUP_DATA_REPAIR=true

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cache opcional com Redis. Se nao preencher, a aplicacao usa cache local em memoria.
REDIS_URL=
CACHE_NAMESPACE=nexora
CACHE_DEFAULT_TTL_SECONDS=900
REDIS_SOCKET_TIMEOUT_SECONDS=0.4
REDIS_RETRY_COOLDOWN_SECONDS=30
