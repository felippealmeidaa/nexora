APP_NAME=NEXORA API
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

DATABASE_URL=sqlite:////srv/nexora/storage/academico.db
AUTO_CREATE_SCHEMA=false

SECRET_KEY=defina-um-segredo-forte-e-unico
LYCEUM_CREDENTIALS_KEY=defina-uma-chave-forte-e-unica
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_COOKIE_NAME=nexora_access
REFRESH_COOKIE_NAME=nexora_refresh
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
MAX_ACTIVE_SESSIONS_PER_USER=5

CORS_ALLOWED_ORIGINS=https://SEU-PROJETO.pages.dev
CORS_ALLOW_CREDENTIALS=true

MAX_UPLOAD_BYTES=209715200
MAX_HISTORICAL_RECORDS_PER_FILE=300000
ENABLE_GEMINI_UPLOAD_FALLBACK=true
ALLOW_LYCEUM_CPF_PASSWORD_FALLBACK=false

ENABLE_DEMO_BOOTSTRAP=false
SEED_EMPTY_DATABASE=false
CREATE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@nexora.local
DEFAULT_ADMIN_PASSWORD=
ENABLE_STARTUP_DATA_REPAIR=true

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

REDIS_URL=
CACHE_NAMESPACE=nexora
CACHE_DEFAULT_TTL_SECONDS=900
REDIS_SOCKET_TIMEOUT_SECONDS=0.4
REDIS_RETRY_COOLDOWN_SECONDS=30
